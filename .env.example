# =============================================================================
# Eureka Pro - Docker Compose Environment Variables
# All service configurations are centralized here
# Copy this file to .env and modify as needed
# =============================================================================

# =============================================================================
# Image Configuration
# =============================================================================
IMAGE_TAG=1.0.0
IMAGE_PREFIX=eureka-pro

# =============================================================================
# Network Configuration
# =============================================================================
NETWORK_NAME=eureka-net

# =============================================================================
# Spring Boot Common Configuration
# =============================================================================
# Active profile for all services (container profile enables environment-based config)
SPRING_PROFILES_ACTIVE=container

# =============================================================================
# Eureka Server Configuration (Shared by all services)
# =============================================================================
# Eureka peer addresses (used by all microservices to register)
EUREKA_PEER_1=eureka-server-1:8761
EUREKA_PEER_2=eureka-server-2:8761

# Eureka client authentication credentials
EUREKA_CLIENT_USERNAME=eureka-client
EUREKA_CLIENT_PASSWORD=client123

# =============================================================================
# Service Ports Configuration
# =============================================================================
# Eureka Server ports
EUREKA_SERVER_1_PORT=8761
EUREKA_SERVER_2_PORT=8762

# Microservice ports
DEMO_SERVICE_A_PORT=8081
DEMO_SERVICE_B_PORT=8082

# Gateway port
GATEWAY_PORT=8080

# =============================================================================
# Service Hostnames (for Eureka instance registration)
# =============================================================================
EUREKA_SERVER_1_HOSTNAME=eureka-server-1
EUREKA_SERVER_2_HOSTNAME=eureka-server-2
DEMO_SERVICE_A_HOSTNAME=demo-service-a
DEMO_SERVICE_B_HOSTNAME=demo-service-b
GATEWAY_HOSTNAME=gateway

# =============================================================================
# Gateway Configuration
# =============================================================================
# Enable/disable gateway authentication
GATEWAY_AUTH_ENABLED=true

# Authentication token for protected routes (/api/b/**)
GATEWAY_AUTH_TOKEN=gateway-token

# =============================================================================
# JVM Configuration (Applied to all services)
# =============================================================================
# Common JVM options for container environment
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# Service-specific JVM memory settings (optional, overrides JAVA_OPTS)
# EUREKA_JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
# SERVICE_JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC
# GATEWAY_JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# =============================================================================
# Resource Limits (Docker Compose deploy.resources)
# =============================================================================
# Eureka Server resources (higher due to registry overhead)
EUREKA_MEMORY_LIMIT=1024m
EUREKA_CPU_LIMIT=1.0
EUREKA_MEMORY_RESERVATION=512m
EUREKA_CPU_RESERVATION=0.5

# Demo Services resources (lighter microservices)
SERVICE_MEMORY_LIMIT=512m
SERVICE_CPU_LIMIT=0.5
SERVICE_MEMORY_RESERVATION=256m
SERVICE_CPU_RESERVATION=0.25

# Gateway resources (moderate, handles routing)
GATEWAY_MEMORY_LIMIT=1024m
GATEWAY_CPU_LIMIT=1.0
GATEWAY_MEMORY_RESERVATION=512m
GATEWAY_CPU_RESERVATION=0.5

# =============================================================================
# Restart Policy
# =============================================================================
# Options: no, on-failure, always, unless-stopped
RESTART_POLICY=unless-stopped

# =============================================================================
# Health Check Configuration
# =============================================================================
# Health check interval (how often to check)
HEALTHCHECK_INTERVAL=15s

# Health check timeout (max time for each check)
HEALTHCHECK_TIMEOUT=5s

# Health check retries (number of failures before unhealthy)
HEALTHCHECK_RETRIES=10

# Health check start period (grace period for startup)
# Eureka servers need more time to initialize
EUREKA_HEALTHCHECK_START_PERIOD=60s

# Other services can start checking sooner
SERVICE_HEALTHCHECK_START_PERIOD=45s

# =============================================================================
# Logging Configuration
# =============================================================================
# Log driver
LOG_DRIVER=json-file

# Maximum size of each log file
LOG_MAX_SIZE=50m

# Maximum number of log files to keep
LOG_MAX_FILE=5

# Service-specific log sizes (optional)
# EUREKA_LOG_MAX_SIZE=50m
# SERVICE_LOG_MAX_SIZE=30m
# GATEWAY_LOG_MAX_SIZE=50m

# =============================================================================
# Build Configuration
# =============================================================================
# Maven build options
MAVEN_SKIP_TESTS=true
MAVEN_QUIET=true

# =============================================================================
# Advanced Configuration (Optional)
# =============================================================================
# Docker network driver
NETWORK_DRIVER=bridge

# Container timezone (optional)
# TZ=Asia/Shanghai

# HTTP proxy (if needed)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,eureka-server-1,eureka-server-2
